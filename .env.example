# Frontend (Client) Environment Variables Example
# Copy this file to .env or add these variables directly in your hosting platform (Vercel, Netlify, Cloudflare)

# Supabase Authentication & Storage Configuration
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_publishable_key
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_publishable_key

# Backend API Endpoint URL
# When running locally: http://localhost:5000/api
# When deployed to cloud (e.g., Render, Railway, AWS): https://your-backend-api.onrender.com/api
VITE_API_URL=http://localhost:5000/api
